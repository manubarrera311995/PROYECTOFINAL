# ── Rutas ────────────────────────────────────────────────────────────────────
# Carpeta que contiene los FEP_*.csv y las carpetas DATA_{year}/
# Por defecto: repo hermano audio-dna en la misma carpeta padre
CSV_DIR=../audio-dna
OUTPUT_BASE=../audio-dna

# ── Paralelismo ───────────────────────────────────────────────────────────────
# Descargas simultáneas (yt-dlp). Recomendado: 3-4
# Con más de 4 workers YouTube puede bloquear temporalmente la IP
DOWNLOAD_WORKERS=4

# Análisis simultáneos (ffmpeg + Essentia). Recomendado: 2-3
# Cada worker carga los modelos TF.js en RAM (~200 MB por worker)
ANALYZE_WORKERS=2

# ── Comportamiento ────────────────────────────────────────────────────────────
# Omitir canciones que ya tienen JSON válido en output-dir
SKIP_EXISTING=true

# Borrar WAV tras análisis exitoso (libera ~30-50 GB por edición)
DELETE_WAV_AFTER=false

# ── Cookies YouTube (para videos age-restricted) ─────────────────────────────
# Opción A — leer cookies del navegador automáticamente (recomendado)
# Valores posibles: chrome, firefox, edge, brave, opera, chromium
# YTDLP_COOKIES_FROM_BROWSER=chrome

# Opción B — archivo de cookies exportado manualmente (más estable)
# YTDLP_COOKIES_FILE=./cookies.txt

# ── Fase 8 — Enriquecimiento Spotify (opcional, post-entrega) ─────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_ENRICH=false
SPOTIFY_OVERRIDE_MOODS=false
