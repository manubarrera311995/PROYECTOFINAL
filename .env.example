# ── Rutas ────────────────────────────────────────────────────────────────────
# Carpeta que contiene los archivos FEP_*.csv
CSV_DIR=./data/csv

# Carpeta base donde se crearán las subcarpetas DATA_{year}/
OUTPUT_BASE=./data/output

# ── Paralelismo ───────────────────────────────────────────────────────────────
# Descargas simultáneas (yt-dlp). Recomendado: 2. Subir a 3-4 aumenta riesgo de rate-limit.
DOWNLOAD_WORKERS=2

# Análisis simultáneos (ffmpeg + Essentia). Recomendado: 2-3
# Cada worker carga los modelos TF.js en RAM (~200 MB por worker)
ANALYZE_WORKERS=2

# ── Comportamiento ────────────────────────────────────────────────────────────
# Omitir canciones que ya tienen JSON válido en output-dir
SKIP_EXISTING=true

# Borrar WAV tras análisis exitoso (libera ~30-50 GB por edición)
DELETE_WAV_AFTER=false

# ── Throttling anti-rate-limit ────────────────────────────────────────────────
# Pausa (segundos) entre peticiones HTTP internas de yt-dlp (default 2)
YTDLP_SLEEP_REQUESTS=2
# Pausa (segundos) antes de iniciar cada descarga (default 3)
YTDLP_SLEEP_INTERVAL=3
# Límite superior aleatorio para --max-sleep-interval (dejar vacío = igual a SLEEP_INTERVAL)
# YTDLP_SLEEP_MAX=6

# ── Cookies YouTube (para videos age-restricted) ─────────────────────────────
# Opción A — leer cookies del navegador automáticamente (RECOMENDADO)
# Usa Firefox: inicia sesión con una cuenta de Google/YouTube en Firefox y
# déjalo así configurado. Firefox funciona igual en Windows y macOS.
# (Chrome/Edge suelen fallar en Windows por bloqueo de la base de datos de
# cookies o por el cifrado "App-Bound" — ver MANUAL_USUARIO.md.)
# Valores posibles: firefox, chrome, edge, brave, opera, chromium, safari (solo Mac)
YTDLP_COOKIES_FROM_BROWSER=firefox

# Opción B — archivo de cookies exportado manualmente (menos estable: las
# cookies se invalidan rápido si sigues usando el navegador tras exportarlas)
# YTDLP_COOKIES_FILE=./cookies.txt

# Nota: además de las cookies, para descargar videos con restricción de edad
# necesitas tener instalado un runtime de JavaScript (Deno recomendado).
# Ver "Paso 1" en MANUAL_USUARIO.md — el pipeline detecta a Deno solo.

# ── Spotify ────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_ENRICH=false
